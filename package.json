{
	"name": "farbfeld-viewer",
	"displayName": "Farbfeld Viewer",
	"description": "Farbfeld (.ff) image viewer",
	"version": "1.0.2",
	"publisher": "ninjaz5736",
	"private": true,
	"license": "0BSD",
	"repository": {
		"type": "git",
		"url": "https://github.com/ninjaz5736/ff-vscode"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"contributes": {
		"customEditors": [
			{
				"viewType": "ninjaz5736.farbfeld",
				"displayName": "Farbfeld",
				"selector": [
					{
						"filenamePattern": "*.ff"
					}
				]
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"watch": "tsc -w -p ./",
		"package": "npx @vscode/vsce package"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/vscode": "^1.100.0",
		"eslint": "^9.13.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}
